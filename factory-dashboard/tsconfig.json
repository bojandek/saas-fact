{
  "compilerOptions": {
    "target": "es2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@saas-factory/auth": ["../packages/auth/src/index.ts"],
      "@saas-factory/db": ["../packages/db/src/index.ts"],
      "@saas-factory/ui": ["../packages/ui/src/index.ts"],
      "@saas-factory/core": ["../packages/core/src/index.ts"],
      "@saas-factory/shared-types": ["../packages/shared-types/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../factory-brain/src/**/*.ts"
  ],
  "exclude": ["node_modules", "../factory-brain/src/**/*.test.ts", "../factory-brain/src/**/*.spec.ts"]
}
