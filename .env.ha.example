# High Availability Infrastructure Configuration
# Copy this file to .env.ha and customize for your environment

# ============================================================================
# PostgreSQL Configuration
# ============================================================================

DB_HOST=postgres-primary
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=saas_factory
DB_REPLICA_HOSTS=postgres-replica-1,postgres-replica-2
DB_REPLICA_PORTS=5432,5432

# Connection pool settings
DB_MAX_PRIMARY_CONNECTIONS=50
DB_MAX_REPLICA_CONNECTIONS=100
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=2000
DB_STATEMENT_TIMEOUT_MS=30000

# Replication settings
DB_WAL_LEVEL=replica
DB_MAX_WAL_SENDERS=10
DB_CHECKPOINT_TIMEOUT=5min
DB_CHECKPOINT_COMPLETION_TARGET=0.9

# Point-in-time recovery (PITR) settings
DB_ARCHIVE_MODE=on
DB_ARCHIVE_COMMAND='test ! -f /mnt/wal_archive/%f && cp %p /mnt/wal_archive/%f'
DB_WAL_RETENTION_TIME=24h

# ============================================================================
# Redis Sentinel Configuration
# ============================================================================

REDIS_SENTINEL_HOSTS=redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379
REDIS_MASTER_NAME=mymaster
REDIS_PASSWORD=

# Cache settings
REDIS_CACHE_TTL_SECONDS=3600
REDIS_CACHE_MAX_SIZE=1000000
REDIS_ENABLE_OFFLINE_QUEUE=true

# Sentinel monitoring
REDIS_SENTINEL_QUORUM=2
REDIS_SENTINEL_DOWN_AFTER_MS=30000
REDIS_SENTINEL_PARALLEL_SYNCS=1
REDIS_SENTINEL_FAILOVER_TIMEOUT=180000

# ============================================================================
# Neo4j Configuration
# ============================================================================

NEO4J_URI=neo4j+s://neo4j-core-1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# Neo4j HA cluster settings
NEO4J_CLUSTER_SIZE=3
NEO4J_MAX_CONNECTION_POOL_SIZE=100
NEO4J_CONNECTION_ACQUISITION_TIMEOUT_MS=60000
NEO4J_ENCRYPTED=true

# Read/write separation
NEO4J_READ_PREFERENCE=READ_FOLLOWERS
NEO4J_WRITE_PREFERENCE=WRITE_PRIMARY

# ============================================================================
# High Availability Settings
# ============================================================================

# Health check configuration
HEALTH_CHECK_INTERVAL_MS=30000
HEALTH_CHECK_TIMEOUT_MS=5000
HEALTH_CHECK_RETRIES=5

# Failover configuration
FAILOVER_ENABLED=true
FAILOVER_AUTO_PROMOTE=true
FAILOVER_HEALTH_CHECK_INTERVAL_MS=30000
FAILOVER_PRIMARY_THRESHOLD=3  # Failures before demotion
FAILOVER_REPLICA_THRESHOLD=2   # Failures before exclusion

# Replication configuration
REPLICATION_MODE=streaming
REPLICATION_CONFLICT_RESOLUTION=last-write-wins
REPLICATION_MAX_LAG_MS=5000
REPLICATION_SYNC_TIMEOUT_MS=30000
REPLICATION_RETRY_MAX_ATTEMPTS=3
REPLICATION_RETRY_BACKOFF_MS=1000

# Vector clock configuration (multi-region)
VECTOR_CLOCK_MAX_EVENTS=10000
VECTOR_CLOCK_PRUNE_INTERVAL_MS=60000

# ============================================================================
# Monitoring & Observability
# ============================================================================

PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL_SECONDS=15

GRAFANA_ENABLED=true
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# ============================================================================
# Admin API Security
# ============================================================================

HA_ADMIN_KEY=your-secure-admin-key-here-min-32-chars-long
HA_ADMIN_RATE_LIMIT_PER_MINUTE=10

# ============================================================================
# Regional Configuration (for multi-region)
# ============================================================================

PRIMARY_REGION=us-east-1
SECONDARY_REGION=eu-west-1
TERTIARY_REGION=ap-southeast-1

PRIMARY_ENDPOINT=http://api-us-east-1:3000
SECONDARY_ENDPOINT=http://api-eu-west-1:3000
TERTIARY_ENDPOINT=http://api-ap-southeast-1:3000

# Route53 Health Check
ROUTE53_HEALTH_CHECK_ENABLED=false
ROUTE53_HEALTH_CHECK_INTERVAL=30

# ============================================================================
# Logging & Debugging
# ============================================================================

LOG_LEVEL=info
DEBUG_HA_EVENTS=false
DEBUG_REPLICATION_EVENTS=false
DEBUG_FAILOVER_EVENTS=false

SENTRY_DSN=

# ============================================================================
# Feature Flags
# ============================================================================

FEATURE_HA_READ_WRITE_SPLITTING=true
FEATURE_AUTOMATIC_FAILOVER=true
FEATURE_MULTI_REGION=false
FEATURE_CHAOS_TESTING=false
