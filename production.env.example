# Production Environment Variables
# Copy this to production environment and fill in actual values

# ============================================
# SUPABASE (Production Project)
# ============================================
# Get from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# STRIPE (Production/Live Keys)
# ============================================
# IMPORTANT: Use LIVE keys (pk_live_*, sk_live_*)
# Get from: Stripe Dashboard → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx...
STRIPE_SECRET_KEY=sk_live_xxxxx...

# Webhook Secret
# Get from: Stripe Dashboard → Developers → Webhooks
# Create webhook for: https://yourdomain.com/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_xxxxx...

# ============================================
# RESEND (Email Service)
# ============================================
# Get from: Resend → API Keys
RESEND_API_KEY=re_xxxxx...

# IMPORTANT: Use verified domain in Resend
# This must match a verified sending domain
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Your production domain
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Environment type
NODE_ENV=production

# ============================================
# OPTIONAL: Advanced Configuration
# ============================================

# Database
# DATABASE_URL=postgresql://user:password@host:5432/database

# Logging
# LOG_LEVEL=info

# Feature Flags
# ENABLE_ANALYTICS=true
# ENABLE_ADVANCED_FEATURES=true

# Rate Limiting
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW_MS=3600000

# Email Templates
# CUSTOM_EMAIL_TEMPLATE_PATH=/app/custom-templates

# Webhooks
# WEBHOOK_TIMEOUT_MS=30000
# WEBHOOK_RETRY_COUNT=3

# ============================================
# SECURITY NOTES
# ============================================
# 🔒 NEVER commit this file with real values
# 🔒 Store actual values in Coolify environment
# 🔒 Use strong, unique keys for each environment
# 🔒 Rotate keys regularly
# 🔒 Enable IP whitelisting in Stripe if possible
# 🔒 Configure CORS for your domain
# 🔒 Use HTTPS only (_verified by SSL cert_)

# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 1. Create Supabase production project
# 2. Create Stripe live account
# 3. Setup Resend domain verification
# 4. Copy values to Coolify environment
# 5. Deploy to production
# 6. Test with real account credentials
# 7. Monitor for errors in logs
