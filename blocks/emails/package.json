{
  "name": "@saas-factory/blocks-emails",
  "version": "0.0.1",
  "description": "Emails block with Resend + React Email",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite build --watch",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.vite"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "@types/node": "^22.7.4",
    "eslint": "^9.12.0",
    "@types/react": "^18.3.3"
  },
  "dependencies": {
    "resend": "^3.3.0",
    "react-email": "^1.8.2",
    "@react-email/components": "^0.0.29",
    "@saas-factory/core": "workspace:*",
    "@saas-factory/ui": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18"
  }
}