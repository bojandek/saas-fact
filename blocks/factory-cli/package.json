    "@saas-factory/free-for-dev": "workspace:*",
    "@saas-factory/factory-brain": "workspace:*",
    "commander": "^11.0.0",
    "chalk": "^5.3.0",
    "ora": "^7.0.1",
    "table": "^6.8.0",
