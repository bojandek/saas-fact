{
  "compilerOptions": {
    "baseUrl": "../..",
    "outDir": "./dist",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "strict": false,
    "noEmitOnError": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "lib": ["ES2020"],
    "paths": {
      "@saas-factory/factory-brain": ["factory-brain/src/index.ts"],
      "@saas-factory/factory-brain/*": ["factory-brain/src/*"]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
