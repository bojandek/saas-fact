{
  "name": "@saas-factory/blocks-database",
  "version": "0.0.1",
  "description": "Database schemas, migrations, and queries for multi-tenant Supabase",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite build --watch",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.vite",
    "db:generate": "supabase gen types typescript --local > src/types.ts",
    "db:migrate": "supabase migration new"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "@types/node": "^22.7.4",
    "eslint": "^9.12.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "@saas-factory/core": "workspace:*",
    "@saas-factory/db": "workspace:*"
  }
}