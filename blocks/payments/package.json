{
  "name": "@saas-factory/blocks-payments",
  "version": "0.0.1",
  "description": "Payments block with Stripe integration",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite build --watch",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.vite"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "@types/node": "^22.7.4",
    "eslint": "^9.12.0",
    "@types/react": "^18.3.3"
  },
  "dependencies": {
    "stripe": "^16.2.0",
    "@stripe/stripe-js": "^4.2.0",
    "@stripe/react-stripe-js": "^2.2.1",
    "@saas-factory/core": "workspace:*",
    "@saas-factory/db": "workspace:*",
    "@saas-factory/ui": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18",
    "next": "^15"
  }
}