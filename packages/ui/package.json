    "react": "^18",
    "react-dom": "^18",
    "typescript": "^5",
    "vite": "^5",
    "vitest": "^1.6.0",
    "@testing-library/react": "^16.3.0",
    "jsdom": "^28.1.0",
    "@storybook/react": "^8.0.0",
    "@storybook/addon-essentials": "^8.0.0",
    "@storybook/addon-interactions": "^8.0.0",
    "@storybook/addon-a11y": "^8.0.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.35",
    "autoprefixer": "^10.4.17"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
