{
  "name": "@saas-factory/core",
  "version": "0.0.1",
  "description": "Core utilities and shared types for SaaS Factory",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite build --watch",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.vite"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "@types/node": "^22.7.4",
    "eslint": "^9.12.0"
  },
  "dependencies": {
    "zod": "^3.23.8"
  }
}