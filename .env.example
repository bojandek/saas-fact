# ============================================================
# SaaS Factory — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================================

# ─── Supabase ────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=your-access-token

# Multi-schema support (optional, defaults to 'public')
NEXT_PUBLIC_SUPABASE_SCHEMA=public
SUPABASE_SCHEMA=public

# ─── OpenAI (samo za Whisper audio transkripciju) ────────────
# Opcionalno — potrebno samo ako koristiš audio/video ingest
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── Anthropic Claude (PRIMARAN LLM provider) ───────────────
# OBAVEZNO — svi agenti koriste Claude
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Voyage AI (embeddings za RAG sistem) ────────────────────
# Preporučeno — Anthropic-preporučeni embedding provider
# Get from: https://www.voyageai.com/
VOYAGE_API_KEY=pa-...

# ─── Gemini (optional) ───────────────────────────────────────
GEMINI_API_KEY=your-gemini-key

# ─── Stripe ──────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
STRIPE_AGENCY_MONTHLY_PRICE_ID=price_...
STRIPE_AGENCY_YEARLY_PRICE_ID=price_...

# ─── Resend (email) ──────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
NOTIFICATION_FROM_EMAIL=noreply@yourdomain.com
EMAIL_FROM=noreply@yourdomain.com

# ─── Twilio (SMS notifications, optional) ────────────────────
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1234567890

# ─── Coolify (deployment) ────────────────────────────────────
# Get from: your Coolify instance → Settings → API Keys
COOLIFY_API_URL=https://your-coolify.com
COOLIFY_API_KEY=your-coolify-api-key
COOLIFY_API_TOKEN=your-coolify-token

# ─── Factory Dashboard ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
FACTORY_DASHBOARD_URL=http://localhost:3000
FACTORY_API_TOKEN=your-internal-api-token

# ─── Job Queue ───────────────────────────────────────────────
JOB_QUEUE_CONCURRENCY=3
JOB_QUEUE_MAX_SIZE=100

# ─── Apps Directory (where generated SaaS apps are stored) ───
APPS_DIR=/home/ubuntu/generated-apps

# ─── OpenCrawl (web research, optional) ──────────────────────
OPEN_CRAWL_SERVICE_URL=https://your-opencrawl-instance.com

# ─── Monitoring & Alerts (optional) ──────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_CHANNEL=#saas-factory-alerts
SLACK_WARNING_MENTIONS=@here
SLACK_CRITICAL_MENTIONS=@channel
SENTRY_DSN=https://...@sentry.io/...
PAGERDUTY_SERVICE_ID=your-service-id
PAGERDUTY_INTEGRATION_KEY=your-integration-key
EMAIL_RECIPIENTS=admin@yourdomain.com
EMAIL_CRITICAL_RECIPIENTS=oncall@yourdomain.com

# ─── Svix (webhooks, optional) ───────────────────────────────
SVIX_TOKEN=your-svix-token
SVIX_SERVER_URL=https://api.svix.com

# ─── Node Environment ────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
